function switchTab(pageId, btn) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-bar button').forEach(b => b.classList.remove('active'));
  document.getElementById(pageId).classList.add('active');
  btn.classList.add('active');
  if (pageId === 'pageStats') renderStats();
  if (pageId === 'pageSettings') renderSettings();
  if (pageId === 'pageRecords') renderRecords();
}

// ==================== MODAL ====================
function openModal(type) {
  currentType = type;
  document.getElementById('modalTitle').textContent = type === 'income' ? '记一笔收入' : '记一笔支出';
  setType(type);
  document.getElementById('amount').value = '';
  document.getElementById('desc').value = '';
  document.getElementById('date').value = new Date().toISOString().split('T')[0];
  updateCategorySelect();
  document.getElementById('modalOverlay').classList.add('active');
  setTimeout(() => document.getElementById('amount').focus(), 300);
}

function closeModal(e) {
  if (e && e.target !== document.getElementById('modalOverlay')) return;
  document.getElementById('modalOverlay').classList.remove('active');
}

function setType(type) {
  currentType = type;
  document.getElementById('typeIncomeBtn').className = type === 'income' ? 'active-income' : '';
  document.getElementById('typeExpenseBtn').className = type === 'expense' ? 'active-expense' : '';
  updateCategorySelect();
}

function updateCategorySelect() {
  const cats = currentType === 'income' ? incomeCats : expenseCats;
  document.getElementById('category').innerHTML = cats.map(c =>
    `<option value="${c.name}">${c.icon} ${c.name}</option>`
  ).join('');
}

async function saveTx() {
  const amount = parseFloat(document.getElementById('amount').value);
  if (!amount || amount <= 0) { showToast('请输入有效金额'); return; }
  const tx = {
    id: Date.now(),
    type: currentType,
    amount: Math.round(amount * 100) / 100,
    category: document.getElementById('category').value,
    desc: document.getElementById('desc').value.trim(),
    date: document.getElementById('date').value
  };
  transactions.push(tx);
  localStorage.setItem('tx', JSON.stringify(transactions));
  await cloudAddTx(tx);
  renderRecords();
  document.getElementById('modalOverlay').classList.remove('active');
  showToast('已保存 ✓');
}

async function deleteTx(id) {
  transactions = transactions.filter(t => t.id !== id);
  localStorage.setItem('tx', JSON.stringify(transactions));
  await cloudDeleteTx(id);
  renderRecords();
  showToast('已删除');
}

function setFilter(filter, btn) {
  currentFilter = filter;
  document.querySelectorAll('.filters button').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderRecords();
}

// ==================== CSV ====================
function exportCSV() {
  if (transactions.length === 0) { showToast('没有数据可导出'); return; }
  const header = '类型,金额,分类,备注,日期';
  const rows = transactions.map(t =>
    `${t.type === 'income' ? '收入' : '支出'},${t.amount},${t.category},"${t.desc || ''}",${t.date}`
  );
  const csv = '﻿' + header + '\n' + rows.join('\n');
  const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `日常记账_${new Date().toISOString().split('T')[0]}.csv`;
  a.click();
  URL.revokeObjectURL(url);
  showToast('导出成功 ✓');
}

async function importCSV(event) {
  const file = event.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = async function(e) {
    const text = e.target.result;
    const lines = text.split('\n').filter(l => l.trim());
    if (lines.length < 2) { showToast('CSV 格式无效'); return; }
    let imported = 0;
    for (let i = 1; i < lines.length; i++) {
      const parts = parseCSVLine(lines[i]);
      if (parts.length < 4) continue;
      const type = parts[0].includes('收入') ? 'income' : 'expense';
      const amount = parseFloat(parts[1]);
      if (isNaN(amount) || amount <= 0) continue;
      const tx = {
        id: Date.now() + imported,
        type,
        amount: Math.round(amount * 100) / 100,
        category: parts[2],
        desc: parts[3] || '',
        date: parts[4] || new Date().toISOString().split('T')[0]
      };
      transactions.push(tx);
      await cloudAddTx(tx);
      imported++;
    }
    localStorage.setItem('tx', JSON.stringify(transactions));
    renderRecords();
    showToast(`导入了 ${imported} 条记录 ✓`);
  };
  reader.readAsText(file, 'UTF-8');
  event.target.value = '';
}

function parseCSVLine(line) {
  const result = [];
  let current = '';
  let inQuotes = false;
  for (const ch of line) {
    if (ch === '"') { inQuotes = !inQuotes; continue; }
    if (ch === ',' && !inQuotes) { result.push(current.trim()); current = ''; continue; }
    current += ch;
  }
  result.push(current.trim());
  return result;
}

async function clearAll() {
  if (transactions.length === 0) { showToast('没有数据'); return; }
  if (!confirm(`确定要删除全部 ${transactions.length} 条记录吗？此操作不可恢复！`)) return;
  await cloudClearAll();
  transactions = [];
  localStorage.setItem('tx', JSON.stringify(transactions));
  renderRecords();
  renderStats();
  showToast('已清空全部数据');
}

// ==================== TOAST ====================
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(t._timeout);
  t._timeout = setTimeout(() => t.classList.remove('show'), 1800);
}

