// ==================== REAL-TIME SYNC ====================
let realtimeChannel = null;

function setupRealtime() {
  if (!supabase || !userId) return;
  if (realtimeChannel) supabase.removeChannel(realtimeChannel);

  realtimeChannel = supabase
    .channel('tx-changes')
    .on('postgres_changes',
      { event: '*', schema: 'public', table: 'transactions', filter: `user_id=eq.${userId}` },
      async () => {
        // 另一台设备修改了数据，重新加载
        await loadFromCloud();
        renderRecords();
        updateSyncUI();
      }
    )
    .subscribe();
}

// ==================== RENDER ====================
function renderRecords() {
  const monthTx = getMonthTransactions();
  const totalIn = monthTx.filter(t => t.type === 'income').reduce((s, t) => s + t.amount, 0);
  const totalOut = monthTx.filter(t => t.type === 'expense').reduce((s, t) => s + t.amount, 0);
  const balance = totalIn - totalOut;

  document.getElementById('balance').textContent = formatMoney(balance);
  document.getElementById('balance').className = 'balance-amount ' + (balance >= 0 ? 'positive' : 'negative');
  document.getElementById('totalIncome').textContent = formatMoney(totalIn);
  document.getElementById('totalExpense').textContent = formatMoney(totalOut);

  let list = [...transactions].reverse();
  if (currentFilter !== 'all') list = list.filter(t => t.type === currentFilter);

  const shown = currentFilter === 'all' ? monthTx : monthTx.filter(t => t.type === currentFilter);
  const shownIn = shown.filter(t => t.type === 'income').reduce((s, t) => s + t.amount, 0);
  const shownOut = shown.filter(t => t.type === 'expense').reduce((s, t) => s + t.amount, 0);
  document.getElementById('monthSummary').innerHTML =
    `<span>本月<span class="in">收 ${formatMoney(shownIn)}</span> · <span class="out">支 ${formatMoney(shownOut)}</span></span><span>${list.length} 笔记录</span>`;

  const container = document.getElementById('txList');
  if (list.length === 0) {
    container.innerHTML = `<div class="empty"><div class="icon">📝</div><p>还没有记录，开始记账吧</p></div>`;
  } else {
    container.innerHTML = list.map(t => {
      const isIncome = t.type === 'income';
      const d = new Date(t.date);
      const ds = `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
      return `
        <div class="tx-item">
          <div class="tx-icon ${t.type}">${getCatIcon(t.category)}</div>
          <div class="tx-info">
            <div class="tx-category">${t.category}</div>
            ${t.desc ? `<div class="tx-desc">${escHtml(t.desc)}</div>` : ''}
            <div class="tx-date">${ds}</div>
          </div>
          <div class="tx-right">
            <div class="tx-amount ${t.type}">${isIncome ? '+' : '-'}${t.amount.toFixed(2)}</div>
          </div>
          <button class="tx-delete" onclick="deleteTx(${t.id})" title="删除">🗑</button>
        </div>`;
    }).join('');
  }
  updateSyncUI();
}

function escHtml(s) {
  const d = document.createElement('div');
  d.textContent = s;
  return d.innerHTML;
}

// ==================== CHARTS ====================
const CHART_COLORS = ['#3b82f6','#f59e0b','#8b5cf6','#ec4899','#06b6d4','#84cc16','#f97316','#6366f1','#14b8a6','#e11d48','#a855f7','#0ea5e9'];

function renderStats() {
  drawPieChart();
  drawBarChart();
}

function drawPieChart() {
  const canvas = document.getElementById('pieChart');
  const ctx = canvas.getContext('2d');
  const legendEl = document.getElementById('pieLegend');
  const emptyEl = document.getElementById('pieEmpty');
  const wrap = canvas.parentElement;

  const monthTx = getMonthTransactions().filter(t => t.type === 'expense');
  if (monthTx.length === 0) {
    wrap.style.display = 'none';
    legendEl.style.display = 'none';
    emptyEl.style.display = 'block';
    return;
  }
  wrap.style.display = '';
  legendEl.style.display = '';
  emptyEl.style.display = 'none';

  const catMap = {};
  let total = 0;
  for (const t of monthTx) {
    catMap[t.category] = (catMap[t.category] || 0) + t.amount;
    total += t.amount;
  }

  const entries = Object.entries(catMap).sort((a,b) => b[1] - a[1]);
  const dpr = window.devicePixelRatio || 1;
  const size = 300;
  canvas.width = size * dpr;
  canvas.height = size * dpr;
  canvas.style.width = size + 'px';
  canvas.style.height = size + 'px';
  ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

  const cx = size / 2, cy = size / 2, outerR = 110, innerR = 60;
  ctx.clearRect(0, 0, size, size);

  let angle = -Math.PI / 2;
  entries.forEach((entry, i) => {
    const slice = (entry[1] / total) * Math.PI * 2;
    ctx.beginPath();
    ctx.moveTo(cx, cy);
    ctx.arc(cx, cy, outerR, angle, angle + slice);
    ctx.closePath();
    ctx.fillStyle = CHART_COLORS[i % CHART_COLORS.length];
    ctx.fill();

    const mid = angle + slice / 2;
    const lx = cx + Math.cos(mid) * (outerR + 20);
    const ly = cy + Math.sin(mid) * (outerR + 20);
    ctx.fillStyle = '#666';
    ctx.font = '12px -apple-system, sans-serif';
    ctx.textAlign = mid > Math.PI / 2 || mid < -Math.PI / 2 ? 'right' : 'left';
    ctx.fillText(entry[0], lx, ly + 4);

    angle += slice;
  });

  ctx.beginPath();
  ctx.arc(cx, cy, innerR, 0, Math.PI * 2);
  ctx.fillStyle = '#fff';
  ctx.fill();
  ctx.fillStyle = '#333';
  ctx.font = 'bold 16px -apple-system, sans-serif';
  ctx.textAlign = 'center';
  ctx.fillText('支出', cx, cy - 4);
  ctx.font = 'bold 14px -apple-system, sans-serif';
  ctx.fillText('¥' + total.toFixed(0), cx, cy + 18);

  legendEl.innerHTML = entries.map((e, i) =>
    `<div class="legend-item"><span class="legend-dot" style="background:${CHART_COLORS[i % CHART_COLORS.length]}"></span>${e[0]} ¥${e[1].toFixed(0)}</div>`
  ).join('');
}

function drawBarChart() {
  const canvas = document.getElementById('barChart');
  const ctx = canvas.getContext('2d');
  const emptyEl = document.getElementById('barEmpty');
  const wrap = canvas.parentElement;

  if (transactions.length === 0) {
    wrap.style.display = 'none';
    emptyEl.style.display = 'block';
    return;
  }
  wrap.style.display = '';
  emptyEl.style.display = 'none';

  const months = [];
  const now = new Date();
  for (let i = 5; i >= 0; i--) {
    const d = new Date(now.getFullYear(), now.getMonth() - i, 1);
    months.push({
      label: d.getFullYear() + '.' + (d.getMonth() + 1),
      year: d.getFullYear(),
      month: d.getMonth()
    });
  }

  const data = months.map(m => {
    let inc = 0, exp = 0;
    for (const t of transactions) {
      const d = new Date(t.date);
      if (d.getFullYear() === m.year && d.getMonth() === m.month) {
        if (t.type === 'income') inc += t.amount;
        else exp += t.amount;
      }
    }
    return { label: m.label, inc, exp };
  });

  const dpr = window.devicePixelRatio || 1;
  const w = 340, h = 220;
  canvas.width = w * dpr;
  canvas.height = h * dpr;
  canvas.style.width = w + 'px';
  canvas.style.height = h + 'px';
  ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  ctx.clearRect(0, 0, w, h);

  const pad = { top: 16, right: 20, bottom: 32, left: 50 };
  const chartW = w - pad.left - pad.right;
  const chartH = h - pad.top - pad.bottom;
  const maxVal = Math.max(...data.map(d => Math.max(d.inc, d.exp)), 1);
  const barGap = 14;
  const groupW = chartW / data.length;
  const barW = (groupW - barGap) / 2;

  ctx.strokeStyle = '#e5e5e5';
  ctx.lineWidth = 1;
  for (let i = 0; i <= 4; i++) {
    const y = pad.top + (chartH / 4) * i;
    ctx.beginPath();
    ctx.moveTo(pad.left, y);
    ctx.lineTo(w - pad.right, y);
    ctx.stroke();
    ctx.fillStyle = '#999';
    ctx.font = '10px -apple-system, sans-serif';
    ctx.textAlign = 'right';
    ctx.fillText('¥' + Math.round(maxVal * (1 - i / 4)), pad.left - 6, y + 4);
  }

  data.forEach((d, i) => {
    const gx = pad.left + groupW * i;
    const incH = (d.inc / maxVal) * chartH;
    const expH = (d.exp / maxVal) * chartH;
    ctx.fillStyle = '#22c55e';
    ctx.fillRect(gx, pad.top + chartH - incH, barW, incH);
    ctx.fillStyle = '#ef4444';
    ctx.fillRect(gx + barW + barGap, pad.top + chartH - expH, barW, expH);
    ctx.fillStyle = '#666';
    ctx.font = '11px -apple-system, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText(d.label, gx + groupW / 2, h - 6);
  });
}

