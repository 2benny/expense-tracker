<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>生成 App 图标</title>
<style>
  body {
    font-family: -apple-system, BlinkMacSystemFont, sans-serif;
    background: #f5f5f5;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    margin: 0;
    flex-direction: column;
    gap: 20px;
  }
  。card {
    background: #fff;
    border-radius: 16px;
    padding: 32px;
    text-align: center;
    box-shadow: 0 1px 3px rgba(0,0,0,.1);
  }
  h2 { margin: 0 0 8px; }
  p { color: #888; font-size: 14px; margin: 0 0 20px; }
  canvas { border-radius: 16px; margin: 12px; box-shadow: 0 2px 8px rgba(0,0,0,.12); }
  。previews { display: flex; flex-wrap: wrap; justify-content: center; gap: 16px; }
  button {
    padding: 14px 32px;
    border: none;
    border-radius: 12px;
    background: #3b82f6;
    color: #fff;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    margin: 8px;
  }
  button:active { transform: scale(.97); }
  。note { font-size: 12px; color: #aaa; margin-top: 16px; }
</style>
</head>
<body>

<div class="card">
  <h2>📱 生成 App 图标</h2>
  <p>点击按钮下载图标文件到项目文件夹</p>
  <div class="previews">
    <div><canvas id="c192" width="192" height="192"></canvas><div>192×192</div></div>
    <div><canvas id="c512" width="512" height="512"></canvas><div>512×512</div></div>
  </div>
  <div>
    <button onclick="downloadIcon(192)">下载 192px 图标</button>
    <button onclick="downloadIcon(512)">下载 512px 图标</button>
    <button onclick="downloadBoth()">⬇ 一键下载全部</button>
  </div>
  <p class="note">下载后放到 expense-tracker 文件夹即可</p>
</div>

<script>
function drawIcon(canvasId, size) {
  const c = document.getElementById(canvasId);
  const ctx = c.getContext('2d');
  const s = size;

  // Gradient background
  const g = ctx.createLinearGradient(0, 0, s, s);
  g.addColorStop(0, '#3b82f6');
  g.addColorStop(1, '#1d4ed8');
  ctx.fillStyle = g;
  ctx.beginPath();
  ctx.roundRect(0, 0, s, s, s * 0.22);
  ctx.fill();

  // Inner circle
  ctx.fillStyle = 'rgba(255,255,255,0.15)';
  ctx.beginPath();
  ctx.arc(s * 0.5, s * 0.42, s * 0.28, 0, Math.PI * 2);
  ctx.fill();

  // Money bag emoji
  ctx.font = `${s * 0.38}px "Apple Color Emoji", "Segoe UI Emoji", "Noto Color Emoji", sans-serif`;
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillText('💰', s * 0.5, s * 0.43);

  // Text
  ctx.fillStyle = '#fff';
  ctx.font = `bold ${s * 0.13}px -apple-system, BlinkMacSystemFont, sans-serif`;
  ctx.fillText('日常记账', s * 0.5, s * 0.8);
}

function downloadIcon(size) {
  const c = document.getElementById('c' + size);
  c.toBlob(blob => {
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `icon-${size}.png`;
    a.click();
    URL.revokeObjectURL(url);
  });
}

function downloadBoth() {
  downloadIcon(192);
  setTimeout(() => downloadIcon(512), 300);
}

drawIcon('c192', 192);
drawIcon('c512', 512);
</script>
</body>
</html>

<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>日常记账</title>
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<meta name="apple-mobile-web-app-title" content="日常记账">
<meta name="theme-color" content="#3b82f6">
<meta name="description" content="记录日常收入和支出">
<link rel="manifest" href="manifest.json">
<link rel="apple-touch-icon" href="icon-192.png">
<link rel="icon" href="icon-192.png">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
  :root {
    --bg: #f5f5f5;
    --card: #ffffff;
    --text: #1a1a1a;
    --sub: #888;
    --income: #22c55e;
    --expense: #ef4444;
    --primary: #3b82f6;
    --border: #e5e5e5;
    --shadow: 0 1px 3px rgba(0,0,0,.08);
    --tab-height: 64px;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
  }
  .container { max-width: 480px; margin: 0 auto; padding: 16px 16px calc(var(--tab-height) + 24px); }

  /* Header */
  .header {
    text-align: center;
    padding: 24px 0 8px;
    font-size: 20px;
    font-weight: 700;
    letter-spacing: .5px;
  }

  /* Tab Bar */
  .tab-bar {
    position: fixed;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    max-width: 480px;
    background: var(--card);
    border-top: 1px solid var(--border);
    display: flex;
    z-index: 50;
    padding-bottom: env(safe-area-inset-bottom);
  }
  .tab-bar button {
    flex: 1;
    padding: 10px 0 6px;
    border: none;
    background: transparent;
    font-size: 11px;
    color: var(--sub);
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    transition: color .15s;
  }
  .tab-bar button .tb-icon { font-size: 22px; }
  .tab-bar button.active { color: var(--primary); font-weight: 600; }

  /* Pages */
  .page { display: none; }
  .page.active { display: block; }

  /* Balance Card */
  .balance-card {
    background: var(--card);
    border-radius: 16px;
    padding: 24px;
    margin-bottom: 16px;
    box-shadow: var(--shadow);
    text-align: center;
  }
  .balance-label { font-size: 13px; color: var(--sub); margin-bottom: 4px; }
  .balance-amount {
    font-size: 36px;
    font-weight: 700;
    letter-spacing: -1px;
  }
  .balance-amount.positive { color: var(--income); }
  .balance-amount.negative { color: var(--expense); }
  .balance-row {
    display: flex;
    justify-content: center;
    gap: 32px;
    margin-top: 16px;
  }
  .balance-item { text-align: center; }
  .balance-item .label { font-size: 12px; color: var(--sub); }
  .balance-item .value { font-size: 18px; font-weight: 600; }
  .balance-item .value.in { color: var(--income); }
  .balance-item .value.out { color: var(--expense); }

  /* Quick Add */
  .quick-add {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-bottom: 16px;
  }
  .quick-add button {
    padding: 14px;
    border: none;
    border-radius: 12px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: transform .1s;
  }
  .quick-add button:active { transform: scale(.97); }
  .btn-income { background: #dcfce7; color: #166534; }
  .btn-expense { background: #fef2f2; color: #991b1b; }

  /* Form Modal */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,.4);
    display: flex;
    align-items: flex-end;
    z-index: 100;
    opacity: 0;
    pointer-events: none;
    transition: opacity .2s;
  }
  .modal-overlay.active { opacity: 1; pointer-events: auto; }
  .modal {
    background: var(--card);
    width: 100%;
    max-width: 480px;
    margin: 0 auto;
    border-radius: 20px 20px 0 0;
    padding: 24px 20px 32px;
    transform: translateY(100%);
    transition: transform .25s ease-out;
  }
  .modal-overlay.active .modal { transform: translateY(0); }
  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
  }
  .modal-header h3 { font-size: 18px; }
  .modal-close {
    width: 32px; height: 32px;
    border-radius: 50%;
    border: none;
    background: var(--bg);
    font-size: 18px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .form-group { margin-bottom: 16px; }
  .form-group label {
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: var(--sub);
    margin-bottom: 6px;
  }
  .form-group input, .form-group select {
    width: 100%;
    padding: 12px 14px;
    border: 1.5px solid var(--border);
    border-radius: 10px;
    font-size: 16px;
    background: var(--bg);
    outline: none;
    transition: border-color .15s;
  }
  .form-group input:focus, .form-group select:focus { border-color: var(--primary); }
  .type-toggle {
    display: flex;
    border-radius: 10px;
    overflow: hidden;
    border: 1.5px solid var(--border);
  }
  .type-toggle button {
    flex: 1;
    padding: 10px;
    border: none;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    background: var(--bg);
    transition: .15s;
  }
  .type-toggle button.active-income { background: var(--income); color: #fff; }
  .type-toggle button.active-expense { background: var(--expense); color: #fff; }
  .btn-save {
    width: 100%;
    padding: 14px;
    border: none;
    border-radius: 12px;
    background: var(--primary);
    color: #fff;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    margin-top: 8px;
  }

  /* Filters */
  .filters {
    display: flex;
    gap: 8px;
    margin-bottom: 12px;
    overflow-x: auto;
  }
  .filters button {
    padding: 6px 14px;
    border: 1.5px solid var(--border);
    border-radius: 20px;
    background: var(--card);
    font-size: 13px;
    white-space: nowrap;
    cursor: pointer;
  }
  .filters button.active { background: var(--primary); color: #fff; border-color: var(--primary); }

  .month-summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
    font-size: 13px;
    color: var(--sub);
  }
  .month-summary span { font-weight: 600; }
  .month-summary .in { color: var(--income); }
  .month-summary .out { color: var(--expense); }

  /* Transaction List */
  .tx-list { display: flex; flex-direction: column; gap: 8px; }
  .tx-item {
    background: var(--card);
    border-radius: 12px;
    padding: 14px 16px;
    display: flex;
    align-items: center;
    gap: 12px;
    box-shadow: var(--shadow);
  }
  .tx-icon {
    width: 40px; height: 40px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    flex-shrink: 0;
  }
  .tx-icon.income { background: #dcfce7; }
  .tx-icon.expense { background: #fef2f2; }
  .tx-info { flex: 1; min-width: 0; }
  .tx-category { font-size: 14px; font-weight: 600; }
  .tx-desc { font-size: 12px; color: var(--sub); margin-top: 2px; }
  .tx-date { font-size: 11px; color: var(--sub); }
  .tx-right { text-align: right; flex-shrink: 0; }
  .tx-amount { font-size: 16px; font-weight: 700; }
  .tx-amount.income { color: var(--income); }
  .tx-amount.expense { color: var(--expense); }
  .tx-delete {
    width: 28px; height: 28px;
    border: none;
    background: transparent;
    color: #ccc;
    cursor: pointer;
    font-size: 14px;
    border-radius: 6px;
  }
  .tx-delete:hover { color: var(--expense); background: #fef2f2; }

  .empty {
    text-align: center;
    padding: 48px 16px;
    color: var(--sub);
  }
  .empty .icon { font-size: 48px; margin-bottom: 12px; }
  .empty p { font-size: 14px; }

  /* Toast */
  .toast {
    position: fixed;
    top: 20px;
    left: 50%;
    transform: translateX(-50%) translateY(-120px);
    background: #1a1a1a;
    color: #fff;
    padding: 10px 20px;
    border-radius: 20px;
    font-size: 14px;
    z-index: 200;
    transition: transform .2s;
    pointer-events: none;
  }
  .toast.show { transform: translateX(-50%) translateY(0); }

  /* ====== Login Screen ====== */
  #loginScreen {
    position: fixed;
    inset: 0;
    background: var(--bg);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 300;
    flex-direction: column;
    padding: 24px;
  }
  #loginScreen.hidden { display: none; }
  .login-card {
    background: var(--card);
    border-radius: 20px;
    padding: 32px 24px;
    text-align: center;
    box-shadow: var(--shadow);
    max-width: 360px;
    width: 100%;
  }
  .login-card .logo { font-size: 56px; margin-bottom: 12px; }
  .login-card h2 { font-size: 20px; margin-bottom: 4px; }
  .login-card .subtitle { font-size: 13px; color: var(--sub); margin-bottom: 24px; }
  .login-card input {
    width: 100%;
    padding: 14px;
    border: 1.5px solid var(--border);
    border-radius: 12px;
    font-size: 16px;
    text-align: center;
    background: var(--bg);
    outline: none;
    margin-bottom: 12px;
  }
  .login-card input:focus { border-color: var(--primary); }
  .login-card button {
    width: 100%;
    padding: 14px;
    border: none;
    border-radius: 12px;
    background: var(--primary);
    color: #fff;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
  }
  .login-card button:disabled { opacity: .5; pointer-events: none; }
  .login-card .sent { color: var(--income); font-size: 13px; margin-top: 12px; display: none; }
  .login-card .sent.show { display: block; }
  .logout-btn {
    font-size: 11px;
    color: var(--sub);
    cursor: pointer;
    background: none;
    border: none;
    margin-top: 16px;
  }

  /* ====== Statistics Page ====== */
  .stats-section {
    background: var(--card);
    border-radius: 16px;
    padding: 20px;
    margin-bottom: 16px;
    box-shadow: var(--shadow);
  }
  .stats-section h3 { font-size: 15px; margin-bottom: 16px; text-align: center; }
  .chart-wrap { text-align: center; }
  .chart-wrap canvas { max-width: 100%; }
  .legend {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    margin-top: 12px;
  }
  .legend-item {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 12px;
    color: var(--sub);
  }
  .legend-dot {
    width: 10px; height: 10px;
    border-radius: 3px;
    flex-shrink: 0;
  }

  /* ====== Settings Page ====== */
  .settings-section {
    background: var(--card);
    border-radius: 16px;
    padding: 20px;
    margin-bottom: 16px;
    box-shadow: var(--shadow);
  }
  .settings-section h3 { font-size: 15px; margin-bottom: 14px; display: flex; align-items: center; gap: 6px; }
  .setting-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 0;
    border-bottom: 1px solid var(--border);
  }
  .setting-row:last-child { border-bottom: none; }
  .setting-row .label { font-size: 14px; }
  .setting-row .actions { display: flex; gap: 8px; align-items: center; }
  .btn-sm {
    padding: 6px 14px;
    border: 1.5px solid var(--border);
    border-radius: 8px;
    font-size: 13px;
    cursor: pointer;
    background: var(--card);
    transition: .15s;
  }
  .btn-sm.danger { color: var(--expense); border-color: var(--expense); }
  .btn-sm.primary { color: var(--primary); border-color: var(--primary); }
  .btn-sm:hover { opacity: .8; }
  .add-cat-form {
    display: flex;
    gap: 8px;
    margin-top: 12px;
  }
  .add-cat-form input {
    flex: 1;
    padding: 10px 12px;
    border: 1.5px solid var(--border);
    border-radius: 10px;
    font-size: 14px;
    background: var(--bg);
    outline: none;
  }
  .add-cat-form input:focus { border-color: var(--primary); }
  .add-cat-form select {
    width: 60px;
    border: 1.5px solid var(--border);
    border-radius: 10px;
    font-size: 18px;
    text-align: center;
    background: var(--bg);
    cursor: pointer;
  }
  .add-cat-form button {
    padding: 10px 16px;
    border: none;
    border-radius: 10px;
    background: var(--primary);
    color: #fff;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
  }
  .export-btns {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .export-btns button {
    flex: 1;
    min-width: 100px;
    padding: 12px;
    border: 1.5px solid var(--border);
    border-radius: 10px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    background: var(--card);
    transition: .15s;
  }
  .export-btns button.primary { background: var(--primary); color: #fff; border-color: var(--primary); }
  .export-btns button.danger { color: var(--expense); border-color: var(--expense); }

  /* Sync indicator */
  .sync-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    display: inline-block;
    margin-right: 4px;
  }
  .sync-dot.online { background: var(--income); }
  .sync-dot.offline { background: #f59e0b; }
</style>
</head>
<body>

<!-- ==================== LOGIN SCREEN ==================== -->
<div id="loginScreen">
  <div class="login-card">
    <div class="logo">💰</div>
    <h2>日常记账</h2>
    <p class="subtitle">输入邮箱，发送魔法链接登录</p>
    <input type="email" id="loginEmail" placeholder="your@email.com" inputmode="email" autocomplete="email">
    <button id="loginBtn" onclick="sendMagicLink()">发送登录链接</button>
    <p class="sent" id="loginSent">✅ 链接已发送！请检查邮箱，点击链接即可登录</p>
    <button class="logout-btn" onclick="skipLogin()" style="margin-top:24px">跳过登录，本地使用</button>
  </div>
</div>

<!-- ==================== MAIN APP ==================== -->
<div class="container" id="mainApp" style="display:none">

  <!-- Records Page -->
  <div class="page active" id="pageRecords">
    <div class="header">
      💰 日常记账
      <div style="font-size:11px;font-weight:400;color:var(--sub);margin-top:2px">
        <span id="syncStatus"><span class="sync-dot online"></span>已同步</span>
        · <span id="userEmail" style="cursor:pointer" onclick="logout()"></span>
      </div>
    </div>

    <div class="balance-card">
      <div class="balance-label">本月结余</div>
      <div class="balance-amount" id="balance">¥0.00</div>
      <div class="balance-row">
        <div class="balance-item">
          <div class="label">收入</div>
          <div class="value in" id="totalIncome">¥0.00</div>
        </div>
        <div class="balance-item">
          <div class="label">支出</div>
          <div class="value out" id="totalExpense">¥0.00</div>
        </div>
      </div>
    </div>

    <div class="quick-add">
      <button class="btn-income" onclick="openModal('income')">+ 记一笔收入</button>
      <button class="btn-expense" onclick="openModal('expense')">- 记一笔支出</button>
    </div>

    <div class="filters">
      <button class="active" data-filter="all" onclick="setFilter('all', this)">全部</button>
      <button data-filter="income" onclick="setFilter('income', this)">收入</button>
      <button data-filter="expense" onclick="setFilter('expense', this)">支出</button>
    </div>

    <div class="month-summary" id="monthSummary"></div>
    <div class="tx-list" id="txList"></div>
  </div>

  <!-- Statistics Page -->
  <div class="page" id="pageStats">
    <div class="header">📊 统计分析</div>
    <div class="stats-section">
      <h3>📂 本月支出分类</h3>
      <div class="chart-wrap"><canvas id="pieChart" width="300" height="300"></canvas></div>
      <div class="legend" id="pieLegend"></div>
      <div class="empty" id="pieEmpty" style="display:none"><div class="icon">📝</div><p>本月暂无支出记录</p></div>
    </div>
    <div class="stats-section">
      <h3>📅 近6个月收支趋势</h3>
      <div class="chart-wrap"><canvas id="barChart" width="340" height="220"></canvas></div>
      <div class="legend">
        <div class="legend-item"><span class="legend-dot" style="background:var(--income)"></span>收入</div>
        <div class="legend-item"><span class="legend-dot" style="background:var(--expense)"></span>支出</div>
      </div>
      <div class="empty" id="barEmpty" style="display:none"><div class="icon">📝</div><p>暂无历史数据</p></div>
    </div>
  </div>

  <!-- Settings Page -->
  <div class="page" id="pageSettings">
    <div class="header">⚙️ 设置</div>
    <div class="settings-section">
      <h3>📂 收入分类</h3>
      <div id="incomeCatList"></div>
      <div class="add-cat-form">
        <select id="newIncomeIcon">
          <option>💰</option><option>💼</option><option>💪</option><option>📈</option><option>🧧</option><option>🎁</option><option>🏆</option><option>💎</option><option>🎯</option><option>✨</option>
        </select>
        <input type="text" id="newIncomeName" placeholder="新分类名称" maxlength="8">
        <button onclick="addCategory('income')">添加</button>
