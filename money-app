function renderSettings() {
  document.getElementById('incomeCatList').innerHTML = incomeCats.map((c, i) =>
    `<div class="setting-row">
      <span class="label">${c.icon} ${c.name}</span>
      <div class="actions">
        <button class="btn-sm danger" onclick="deleteCategory('income', ${i})">删除</button>
      </div>
    </div>`
  ).join('');
  document.getElementById('expenseCatList').innerHTML = expenseCats.map((c, i) =>
    `<div class="setting-row">
      <span class="label">${c.icon} ${c.name}</span>
      <div class="actions">
        <button class="btn-sm danger" onclick="deleteCategory('expense', ${i})">删除</button>
      </div>
    </div>`
  ).join('');
}

async function addCategory(type) {
  const nameId = type === 'income' ? 'newIncomeName' : 'newExpenseName';
  const iconId = type === 'income' ? 'newIncomeIcon' : 'newExpenseIcon';
  const name = document.getElementById(nameId).value.trim();
  const icon = document.getElementById(iconId).value;
  if (!name) { showToast('请输入分类名称'); return; }
  const cats = type === 'income' ? incomeCats : expenseCats;
  if (cats.some(c => c.name === name)) { showToast('分类已存在'); return; }
  const newCat = { name, icon };
  cats.push(newCat);
  localStorage.setItem(type === 'income' ? 'incomeCats' : 'expenseCats', JSON.stringify(cats));
  await cloudAddCategory(type, newCat);
  document.getElementById(nameId).value = '';
  renderSettings();
  showToast('已添加 ✓');
}

async function deleteCategory(type, index) {
  const cats = type === 'income' ? incomeCats : expenseCats;
  if (cats.length <= 1) { showToast('至少保留一个分类'); return; }
  const removed = cats[index];
  cats.splice(index, 1);
  localStorage.setItem(type === 'income' ? 'incomeCats' : 'expenseCats', JSON.stringify(cats));
  await cloudDeleteCategory(type, removed.name);
  renderSettings();
  updateCategorySelect();
  showToast('已删除');
}

