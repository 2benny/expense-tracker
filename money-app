<script>
// ==================== CONFIG ====================
// 替换为你的 Supabase 项目 URL 和 anon key
// 在 Supabase Dashboard → Settings → API 中找到
const SUPABASE_URL = 'https://jtxgwpaeeowtgpcyxvfr.supabase.co';
const SUPABASE_KEY = 'sb_publishable_ZpOvdROUhcX2vvJPd7AvbA_48yIUqpb';

// ==================== SUPABASE INIT ====================
let supabase = null;
let isOnline = true;
let userId = null;

try {
  if (SUPABASE_URL) {
    supabase = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);
  }
} catch(e) {}

// ==================== DATA STORE ====================
const DEFAULT_INCOME_CATS = [
  { name: '工资', icon: '💼' },
  { name: '兼职', icon: '💪' },
  { name: '投资', icon: '📈' },
  { name: '红包', icon: '🧧' },
  { name: '其他收入', icon: '💰' }
];
const DEFAULT_EXPENSE_CATS = [
  { name: '餐饮', icon: '🍜' },
  { name: '交通', icon: '🚇' },
  { name: '购物', icon: '🛒' },
  { name: '住房', icon: '🏠' },
  { name: '娱乐', icon: '🎮' },
  { name: '医疗', icon: '🏥' },
  { name: '教育', icon: '📚' },
  { name: '其他支出', icon: '💸' }
];

let incomeCats = [...DEFAULT_INCOME_CATS];
let expenseCats = [...DEFAULT_EXPENSE_CATS];
let transactions = [];
let currentType = 'expense';
let currentFilter = 'all';

function getCatIcon(catName) {
  for (const c of [...incomeCats, ...expenseCats]) {
    if (c.name === catName) return c.icon;
  }
  return '💰';
}

function formatMoney(n) {
  if (n === 0) return '¥0.00';
  return (n < 0 ? '-¥' : '¥') + Math.abs(n).toFixed(2);
}

function getMonthTransactions() {
  const now = new Date();
  const start = new Date(now.getFullYear(), now.getMonth(), 1);
  return transactions.filter(t => new Date(t.date) >= start);
}

// ==================== SUPABASE DATA OPS ====================
async function loadFromCloud() {
  if (!supabase || !userId) return false;
  try {
    // Load transactions (all, up to 5000)
    const { data: tx, error: txErr } = await supabase
      .from('transactions')
      .select('*')
      .order('date', { ascending: false })
      .limit(5000);
    if (txErr) throw txErr;
    transactions = tx.map(t => ({
      id: t.id,
      type: t.type,
      amount: parseFloat(t.amount),
      category: t.category,
      desc: t.description || '',
      date: t.date
    }));
    localStorage.setItem('tx', JSON.stringify(transactions));

    // Load categories
    const { data: cats, error: catErr } = await supabase
      .from('categories')
      .select('*')
      .order('id');
    if (catErr) throw catErr;
    const incCats = cats.filter(c => c.type === 'income').map(c => ({ name: c.name, icon: c.icon }));
    const expCats = cats.filter(c => c.type === 'expense').map(c => ({ name: c.name, icon: c.icon }));
    if (incCats.length > 0) incomeCats = incCats;
    if (expCats.length > 0) expenseCats = expCats;
    localStorage.setItem('incomeCats', JSON.stringify(incomeCats));
    localStorage.setItem('expenseCats', JSON.stringify(expenseCats));

    isOnline = true;
    return true;
  } catch(e) {
    console.log('Cloud load failed, using local cache:', e.message);
    isOnline = false;
    return false;
  }
}

function loadFromLocal() {
  const savedTx = localStorage.getItem('tx');
  if (savedTx) transactions = JSON.parse(savedTx);
  const savedInc = localStorage.getItem('incomeCats');
  if (savedInc) incomeCats = JSON.parse(savedInc);
  const savedExp = localStorage.getItem('expenseCats');
  if (savedExp) expenseCats = JSON.parse(savedExp);
  if (transactions.length === 0 && incomeCats.length === 0) {
    incomeCats = [...DEFAULT_INCOME_CATS];
    expenseCats = [...DEFAULT_EXPENSE_CATS];
  }
}

async function cloudAddTx(tx) {
  if (!supabase || !userId) return;
  try {
    await supabase.from('transactions').insert({
      id: tx.id,
      user_id: userId,
      type: tx.type,
      amount: tx.amount,
      category: tx.category,
      description: tx.desc,
      date: tx.date
    });
    isOnline = true;
  } catch(e) {
    console.log('Cloud add failed:', e.message);
    isOnline = false;
  }
}

async function cloudDeleteTx(id) {
  if (!supabase || !userId) return;
  try {
    await supabase.from('transactions').delete().eq('id', id);
    isOnline = true;
  } catch(e) {
    console.log('Cloud delete failed:', e.message);
    isOnline = false;
  }
}

async function cloudClearAll() {
  if (!supabase || !userId) return;
  try {
    await supabase.from('transactions').delete().eq('user_id', userId);
    isOnline = true;
  } catch(e) {
    console.log('Cloud clear failed:', e.message);
    isOnline = false;
  }
}

async function cloudAddCategory(type, cat) {
  if (!supabase || !userId) return;
  try {
    await supabase.from('categories').insert({
      user_id: userId,
      type,
      name: cat.name,
      icon: cat.icon
    });
    isOnline = true;
  } catch(e) { console.log('Cloud add cat failed:', e.message); isOnline = false; }
}

async function cloudDeleteCategory(type, name) {
  if (!supabase || !userId) return;
  try {
    await supabase.from('categories').delete().eq('user_id', userId).eq('type', type).eq('name', name);
    isOnline = true;
  } catch(e) { console.log('Cloud del cat failed:', e.message); isOnline = false; }
}

function updateSyncUI() {
  const el = document.getElementById('syncStatus');
  if (!supabase || !userId) {
    el.innerHTML = '<span class="sync-dot offline"></span>离线模式';
  } else if (isOnline) {
    el.innerHTML = '<span class="sync-dot online"></span>已同步';
  } else {
    el.innerHTML = '<span class="sync-dot offline"></span>等待同步';
  }
}

// ==================== AUTH ====================
async function sendMagicLink() {
  if (!supabase) {
    showToast('请先配置 Supabase 连接');
    return;
  }
  const email = document.getElementById('loginEmail').value.trim();
  if (!email || !email.includes('@')) { showToast('请输入有效邮箱'); return; }

  const btn = document.getElementById('loginBtn');
  btn.disabled = true;
  btn.textContent = '发送中...';

  const { error } = await supabase.auth.signInWithOtp({
    email,
    options: { emailRedirectTo: window.location.href }
  });

  if (error) {
    showToast('发送失败: ' + error.message);
    btn.disabled = false;
    btn.textContent = '发送登录链接';
  } else {
    document.getElementById('loginSent').classList.add('show');
    btn.textContent = '已发送';
    // 本地存储邮箱以便下次使用
    localStorage.setItem('loginEmail', email);
  }
}

async function checkAuth() {
  if (!supabase) {
    // 没有配置 Supabase，直接跳过登录
    skipLogin();
    return;
  }

  const { data: { session } } = await supabase.auth.getSession();
  if (session) {
    userId = session.user.id;
    document.getElementById('userEmail').textContent = session.user.email;
    await loadFromCloud();
    showMainApp();
  } else {
    // 检查 URL 中是否有 magic link 的 hash
    const hash = window.location.hash;
    if (hash && hash.includes('access_token')) {
      const { data: { session: newSession }, error } = await supabase.auth.getSession();
      if (newSession) {
        userId = newSession.user.id;
        document.getElementById('userEmail').textContent = newSession.user.email;
        await loadFromCloud();
        showMainApp();
        window.location.hash = '';
        return;
      }
    }
    // 显示登录页
    const savedEmail = localStorage.getItem('loginEmail');
    if (savedEmail) document.getElementById('loginEmail').value = savedEmail;
    document.getElementById('loginScreen').classList.remove('hidden');
  }
}

function skipLogin() {
  userId = null;
  loadFromLocal();
  showMainApp();
}

function showMainApp() {
  document.getElementById('loginScreen').classList.add('hidden');
  document.getElementById('mainApp').style.display = '';
  document.getElementById('tabBar').style.display = '';
  updateSyncUI();
  updateCategorySelect();
  renderRecords();
  setupRealtime();
