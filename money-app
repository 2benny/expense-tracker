async function logout() {
  if (supabase) await supabase.auth.signOut();
  userId = null;
  transactions = [];
  incomeCats = [...DEFAULT_INCOME_CATS];
  expenseCats = [...DEFAULT_EXPENSE_CATS];
  document.getElementById('loginScreen').classList.remove('hidden');
